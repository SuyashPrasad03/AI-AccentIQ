# ============================================================
# AI Pronunciation Coach — Environment Variables Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── App / General ───────────────────────────────────────────
# Environment: "development" | "staging" | "production"
APP_ENV=development

# Secret key for signing JWTs and session tokens (min 32 random bytes)
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# Token lifetimes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Backend server ───────────────────────────────────────────
# Host and port Uvicorn listens on inside the container
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Comma-separated allowed CORS origins (frontend URL, no trailing slash)
CORS_ORIGINS=http://localhost:5173

# ── MySQL (relational DB) ────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=pronunciation
MYSQL_PASSWORD=changeme_mysql_password
MYSQL_DATABASE=pronunciation_coach

# Full SQLAlchemy DSN (constructed from the above in Settings, but can be overridden)
# MYSQL_DSN=mysql+pymysql://pronunciation:changeme@mysql:3306/pronunciation_coach

# ── MongoDB (document DB) ────────────────────────────────────
MONGO_URI=mongodb://mongo:27017
MONGO_DATABASE=pronunciation_coach

# ── Storage ──────────────────────────────────────────────────
# Backend to use: "local" | "s3"
STORAGE_BACKEND=local

# Absolute path (inside container) where audio files are stored when STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=/app/storage

# S3-compatible storage (used when STORAGE_BACKEND=s3)
S3_BUCKET=pronunciation-coach
S3_REGION=ap-south-1
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Audio processing ─────────────────────────────────────────
# Min/max allowed recording duration in seconds
AUDIO_MIN_DURATION_SECONDS=30
AUDIO_MAX_DURATION_SECONDS=45
# Max upload file size in bytes (default 50 MB)
AUDIO_MAX_SIZE_BYTES=52428800

# ── WhisperX (ASR + forced alignment) ───────────────────────
# Model size: tiny | base | small | medium | large-v2
WHISPERX_MODEL_SIZE=small
# Device: "cpu" | "cuda"
WHISPERX_DEVICE=cpu
# HuggingFace token for gated models (e.g. pyannote diarization)
HF_TOKEN=

# ── OpenRouter / Gemini (LLM) ────────────────────────────────
# API key from https://openrouter.ai/
OPENROUTER_API_KEY=
# Model string passed to OpenRouter
OPENROUTER_MODEL=google/gemini-flash-1.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Email / OTP ──────────────────────────────────────────────
# SMTP provider for transactional email (e.g. Resend, SendGrid)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=changeme_smtp_password
SMTP_FROM_ADDRESS=noreply@pronunciation-coach.example.com
SMTP_FROM_NAME=Pronunciation Coach

# When "true", OTP codes are printed to the console instead of emailed (dev only)
EMAIL_CONSOLE_FALLBACK=true

# ── OTP rate limiting ────────────────────────────────────────
# Max OTP requests per email per hour
OTP_RATE_LIMIT_PER_HOUR=5
OTP_EXPIRY_MINUTES=10

# ── Anonymous quota ──────────────────────────────────────────
ANONYMOUS_FREE_ANALYSES=3

# ── RAG / Embeddings ─────────────────────────────────────────
# Embedding model name (sentence-transformers compatible)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Cosine similarity threshold below which RAG returns a refusal
RAG_SIMILARITY_THRESHOLD=0.35
RAG_TOP_K=5

# ── DPDP / Retention ─────────────────────────────────────────
# Days before raw audio files are auto-purged
AUDIO_RETENTION_DAYS=30
# Version string stamped on consent_events rows (bump when policy changes)
PRIVACY_POLICY_VERSION=1.0

# ── Sentry (optional error tracking) ────────────────────────
SENTRY_DSN=
